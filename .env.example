# HTTP server
PORT=3000

# Decodo / Smartproxy residential proxy credentials (required)
DECODO_USERNAME=your_account_name
DECODO_PASSWORD=your_password
DECODO_HOST=gate.decodo.com
DECODO_PORT=7000
# Auth-username template. {username} and {country} are substituted.
# Common forms: "user-{username}-country-{country}" or "{username}-country-{country}".
# Check your Decodo dashboard for the exact required format.
DECODO_USERNAME_TEMPLATE=user-{username}-country-{country}

# Concurrency & retries
MAX_CONCURRENCY=3
MAX_QUEUE=50
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=8000

# Timeouts (ms)
NAV_TIMEOUT_MS=45000
STREAM_TIMEOUT_MS=120000

# Browser behaviour
HEADLESS=true
HUMANIZE=true
# Debug only: leave the browser open after each attempt for DOM inspection (leaks browsers).
DEBUG_KEEP_BROWSER=false

# Request defaults
DEFAULT_COUNTRY=us

# Logging: trace | debug | info | warn | error
LOG_LEVEL=info

# Optional grok.com selector overrides (comma-separated lists). Leave unset to use defaults.
# SELECTOR_PROMPT_INPUT=
# SELECTOR_SEND_BUTTON=
# SELECTOR_ANSWER_MESSAGE=
# SELECTOR_ANSWER_CONTENT=
# SELECTOR_STOP_BUTTON=
# SELECTOR_COMPLETION_MARKER=
# SELECTOR_SOURCE_LINKS=
# SELECTOR_SOURCES_PANEL=
