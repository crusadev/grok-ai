# HTTP server
PORT=3000

# Decodo / Smartproxy residential proxy credentials (required)
DECODO_USERNAME=your_account_name
DECODO_PASSWORD=your_password
DECODO_HOST=gate.decodo.com
DECODO_PORT=7000
# Auth-username template. {username} and {country} are substituted.
# Common forms: "user-{username}-country-{country}" or "{username}-country-{country}".
# Check your Decodo dashboard for the exact required format.
DECODO_USERNAME_TEMPLATE=user-{username}-country-{country}

# Worker / concurrency
# Sized for a 32 GB i9 box: 16 workers x 1.6 GB mem_limit = 25.6 GB workers,
# leaving ~6 GB for db/redis/api/web/OS. CPU saturates before RAM at this size.
WORKER_CONCURRENCY=1           # scrape jobs in parallel per worker process
MAX_WORKER_REPLICAS=16         # autoscaler ceiling on worker containers
GLOBAL_MAX_CONCURRENT_JOBS=16  # hard cap (RAM budget): replicas x concurrency
TABS_PER_REQUEST=5             # tabs (contexts) raced per request, each its own proxy
MAX_ATTEMPTS=15                # total attempt budget per request across all tabs
JOB_DEADLINE_MS=150000         # abandon a doomed job after this wall-clock time
BROWSER_RECYCLE_AFTER=50       # re-launch the shared worker browser every N jobs

# Timeouts (ms)
NAV_TIMEOUT_MS=12000
STREAM_TIMEOUT_MS=60000

# Browser behaviour
HEADLESS=true
HUMANIZE=true
# Debug only: leave the browser open after each attempt for DOM inspection (leaks browsers).
DEBUG_KEEP_BROWSER=false

# CDN asset cache — serve grok.com CDN assets from a local cache instead of the
# proxy after the first load (big proxy-bandwidth saving; assets are not blocked).
CDN_CACHE_ENABLED=true
CDN_CACHE_DIR=.cache/cdn
CDN_CACHE_HOSTS=cdn.grok.com

# Storage & queue — PostgreSQL + Redis (run `docker compose up -d`).
# Host values (npm run dev + autoscaler); api/worker containers override the
# DATABASE_URL/REDIS_URL hostnames via docker-compose.
DATABASE_URL=postgres://grok:grok@localhost:5433/grok
REDIS_URL=redis://localhost:6380
PG_POOL_MAX=6

# Request defaults
DEFAULT_COUNTRY=us

# Logging: trace | debug | info | warn | error
LOG_LEVEL=info

# Optional grok.com selector overrides (comma-separated lists). Leave unset to use defaults.
# SELECTOR_PROMPT_INPUT=
# SELECTOR_SEND_BUTTON=
# SELECTOR_ANSWER_MESSAGE=
# SELECTOR_ANSWER_CONTENT=
# SELECTOR_STOP_BUTTON=
# SELECTOR_COMPLETION_MARKER=
# SELECTOR_SOURCE_LINKS=
# SELECTOR_SOURCES_PANEL=
